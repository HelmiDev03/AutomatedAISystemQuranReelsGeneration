# =============================================================================
# Islamic Content Automation — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# Model selection (defaults shown)
OPENAI_MODEL_PRIMARY=gpt-5.4-mini
OPENAI_MODEL_COMPLEX=gpt-5.4
OPENAI_IMAGE_MODEL=gpt-image-2

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# For Supabase: postgresql+asyncpg://postgres:password@db.xxx.supabase.co:5432/postgres
# For local Docker: postgresql+asyncpg://automate:automate@localhost:5432/automate
DATABASE_URL=postgresql+asyncpg://automate:automate@localhost:5432/automate

# ─── Redis ───────────────────────────────────────────────────────────────────
# For Upstash: rediss://default:password@your-endpoint.upstash.io:6379
# For local Docker: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ─── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8100
# Collection names (defaults shown)
CHROMA_QURAN_COLLECTION=quran_verses
CHROMA_HADITH_COLLECTION=hadith_collection

# ─── Cloudinary (media storage) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Instagram Graph API ─────────────────────────────────────────────────────
INSTAGRAM_ACCESS_TOKEN=your-long-lived-access-token
INSTAGRAM_BUSINESS_ID=your-ig-business-account-id

# ─── Telegram Bot (human review) ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id

# ─── Pipeline Settings ──────────────────────────────────────────────────────
# Content verification
CONFIDENCE_THRESHOLD=0.85
SIMILARITY_THRESHOLD=0.85

# Posting schedule
POSTING_INTERVAL_MINUTES=55

# Review mode (set to true to require manual approval for ALL posts)
REVIEW_MODE=true

# ─── Edge TTS ────────────────────────────────────────────────────────────────
EDGE_TTS_VOICE_MALE=ar-SA-HamedNeural
EDGE_TTS_VOICE_FEMALE=ar-SA-ZariyahNeural
QURAN_RECITER=ar.alafasy


